{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agent Orb",
  "version": "0.1.10",
  "identifier": "dev.agentorb.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "Agent Orb",
        "width": 48,
        "height": 48,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ]
  }
}
